# Amiend local runtime configuration
# Copy to `.env` for local debugging. Stable defaults live in `core/config.py`.

# Required secrets / service endpoints
JWT_SECRET_KEY=change_me_to_a_long_random_string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
REDIS_PASSWORD=dev_redis_password
LLM_API_KEY=sk-your-api-key

# Local runtime differences
REDIS_HOST=127.0.0.1
CORS_ORIGINS=*

# Mem0
MEM0_ENABLED=false
MEM0_API_KEY=

# Email verification
# Leave SMTP empty for local console-code fallback.
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_DEV_FIXED_CODE=123456

# Optional smoke-test static access tokens
STATIC_ACCESS_TOKENS=

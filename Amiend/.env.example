# FastAPI Starter environment example
# 1) Copy this file to `.env`
# 2) Replace placeholder values
# 3) docker compose up --build

# --- App metadata ---
APP_NAME=FastAPI-Starter
APP_VERSION=0.1.0

# --- JWT / Auth (required) ---
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=10080
STATIC_ACCESS_TOKENS= # optional: token:user_id pairs separated by commas, for smoke tests only

# --- CORS ---
CORS_ORIGINS=*  # comma separated list or "*" for all (avoid "*" in production with cookies)

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password

# --- MongoDB Atlas ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGO_DATABASE=ami

# --- SSE stream settings ---
SSE_HEARTBEAT_INTERVAL_SECONDS=15
SSE_RECONNECT_RETRY_MS=3000
SSE_MAX_CONNECTIONS_PER_USER=3
SSE_EVENT_RETENTION_SECONDS=300

# --- Memory adapter (Mem0 Platform by default when enabled) ---
MEM0_ENABLED=false
MEMORY_ENABLED=false # legacy alias; MEM0_ENABLED takes precedence
MEMORY_PROVIDER=mem0_platform
MEM0_API_KEY=
MEM0_ORG_ID=
MEM0_PROJECT_ID=
MEM0_DEFAULT_AGENT_PREFIX=ami
MEM0_SEARCH_LIMIT=6
MEMORY_BASE_DIR=./core/memory_adapter
MEMORY_VECTOR_STORE_PATH=./core/memory_adapter/storage/memories_db
MEMORY_DEFAULT_USER_ID=demo-user
MEMORY_BACKEND= # legacy alias for MEMORY_PROVIDER
MEMORY_EXTRA=    # optional: custom config (JSON or key=value pairs)

# --- LLM (OpenAI-compatible defaults) ---
DEFAULT_MODEL_PROVIDER=custom
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Provider-specific placeholders (optional; keep only what you use)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao

# --- SMS (Aliyun example; console provider is default fallback) ---
ALI_SMS_ACCESS_KEY_ID=
ALI_SMS_ACCESS_KEY_SECRET=
ALI_SMS_SIGN_NAME=
ALI_SMS_TEMPLATE_CODE=
ALI_SMS_REGION=cn-hangzhou
SMS_CODE_LENGTH=6
SMS_CODE_TTL_SECONDS=300
SMS_RESEND_COOLDOWN_SECONDS=60
SMS_MAX_ATTEMPTS=5
SMS_DAILY_LIMIT_PER_PHONE=20
SMS_TICKET_TTL_SECONDS=600
